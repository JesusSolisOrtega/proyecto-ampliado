      "jobName": "paragraph_1777824820402_1509139194",
      "id": "paragraph_10",
      "dateCreated": "2026-05-03 16:13:40.402",
      "status": "READY"
    },
    {
      "title": "11. Distribucion por tramos de consumo",
      "text": "%spark.sql\nSELECT\n  CASE\n    WHEN consumo_activo_total_wh = 0       THEN '0. Sin consumo'\n    WHEN consumo_activo_total_wh < 500     THEN '1. Bajo  (<500 Wh)'\n    WHEN consumo_activo_total_wh < 2000    THEN '2. Medio (500-2000 Wh)'\n    WHEN consumo_activo_total_wh < 5000    THEN '3. Alto  (2000-5000 Wh)'\n    ELSE                                        '4. Muy alto (>5000 Wh)'\n  END AS tramo,\n  COUNT(*) AS num_registros,\n  ROUND(COUNT(*) * 100.0 / SUM(COUNT(*)) OVER(), 1) AS porcentaje\nFROM consumo\nGROUP BY 1\nORDER BY 1",
      "user": "anonymous",
      "dateUpdated": "2026-05-03 16:13:40.402",
      "progress": 0,
      "config": {
        "editorSetting": {
          "language": "sql",
