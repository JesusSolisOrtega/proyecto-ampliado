      "status": "READY"
    },
    {
      "title": "10. Pico y valle de consumo por hora",
      "text": "%spark.sql\nSELECT hora,\n       ROUND(MAX(consumo), 1) AS pico_wh,\n       ROUND(MIN(consumo), 1) AS valle_wh,\n       ROUND(AVG(consumo), 1) AS media_wh\nFROM (\n  SELECT 'h01' AS hora, h1  AS consumo FROM consumo UNION ALL\n  SELECT 'h02', h2  FROM consumo UNION ALL\n  SELECT 'h03', h3  FROM consumo UNION ALL\n  SELECT 'h04', h4  FROM consumo UNION ALL\n  SELECT 'h05', h5  FROM consumo UNION ALL\n  SELECT 'h06', h6  FROM consumo UNION ALL\n  SELECT 'h07', h7  FROM consumo UNION ALL\n  SELECT 'h08', h8  FROM consumo UNION ALL\n  SELECT 'h09', h9  FROM consumo UNION ALL\n  SELECT 'h10', h10 FROM consumo UNION ALL\n  SELECT 'h11', h11 FROM consumo UNION ALL\n  SELECT 'h12', h12 FROM consumo UNION ALL\n  SELECT 'h13', h13 FROM consumo UNION ALL\n  SELECT 'h14', h14 FROM consumo UNION ALL\n  SELECT 'h15', h15 FROM consumo UNION ALL\n  SELECT 'h16', h16 FROM consumo UNION ALL\n  SELECT 'h17', h17 FROM consumo UNION ALL\n  SELECT 'h18', h18 FROM consumo UNION ALL\n  SELECT 'h19', h19 FROM consumo UNION ALL\n  SELECT 'h20', h20 FROM consumo UNION ALL\n  SELECT 'h21', h21 FROM consumo UNION ALL\n  SELECT 'h22', h22 FROM consumo UNION ALL\n  SELECT 'h23', h23 FROM consumo UNION ALL\n  SELECT 'h24', h24 FROM consumo\n)\nGROUP BY hora\nORDER BY hora",
      "user": "anonymous",
      "dateUpdated": "2026-05-03 16:13:40.402",
      "progress": 0,
      "config": {
        "editorSetting": {
          "language": "sql",
          "editOnDblClick": false,
          "completionKey": "TAB",
          "completionSupport": true
        },
        "colWidth": 12.0,
