    {
      "title": "10. Pico y valle de consumo por hora",
      "text": "%spark.sql\nSELECT hora,\n       ROUND(MAX(consumo), 1) AS pico_wh,\n       ROUND(MIN(consumo), 1) AS valle_wh,\n       ROUND(AVG(consumo), 1) AS media_wh\nFROM (\n  SELECT \u0027h01\u0027 AS hora, h1  AS consumo FROM consumo UNION ALL\n  SELECT \u0027h02\u0027, h2  FROM consumo UNION ALL\n  SELECT \u0027h03\u0027, h3  FROM consumo UNION ALL\n  SELECT \u0027h04\u0027, h4  FROM consumo UNION ALL\n  SELECT \u0027h05\u0027, h5  FROM consumo UNION ALL\n  SELECT \u0027h06\u0027, h6  FROM consumo UNION ALL\n  SELECT \u0027h07\u0027, h7  FROM consumo UNION ALL\n  SELECT \u0027h08\u0027, h8  FROM consumo UNION ALL\n  SELECT \u0027h09\u0027, h9  FROM consumo UNION ALL\n  SELECT \u0027h10\u0027, h10 FROM consumo UNION ALL\n  SELECT \u0027h11\u0027, h11 FROM consumo UNION ALL\n  SELECT \u0027h12\u0027, h12 FROM consumo UNION ALL\n  SELECT \u0027h13\u0027, h13 FROM consumo UNION ALL\n  SELECT \u0027h14\u0027, h14 FROM consumo UNION ALL\n  SELECT \u0027h15\u0027, h15 FROM consumo UNION ALL\n  SELECT \u0027h16\u0027, h16 FROM consumo UNION ALL\n  SELECT \u0027h17\u0027, h17 FROM consumo UNION ALL\n  SELECT \u0027h18\u0027, h18 FROM consumo UNION ALL\n  SELECT \u0027h19\u0027, h19 FROM consumo UNION ALL\n  SELECT \u0027h20\u0027, h20 FROM consumo UNION ALL\n  SELECT \u0027h21\u0027, h21 FROM consumo UNION ALL\n  SELECT \u0027h22\u0027, h22 FROM consumo UNION ALL\n  SELECT \u0027h23\u0027, h23 FROM consumo UNION ALL\n  SELECT \u0027h24\u0027, h24 FROM consumo\n)\nGROUP BY hora\nORDER BY hora",
