      "jobName": "paragraph_1777824820400_1447473776",
      "id": "paragraph_03",
      "dateCreated": "2026-05-03 16:13:40.401",
      "status": "READY"
    },
    {
      "title": "4. Consumo por tipo de tarifa",
      "text": "%spark.sql\nSELECT tarifa,\n       COUNT(*)                                        AS num_registros,\n       ROUND(AVG(consumo_activo_total_wh), 2)          AS consumo_medio_wh,\n       ROUND(SUM(consumo_activo_total_wh) / 1000, 2)   AS consumo_total_kwh\nFROM consumo\nGROUP BY tarifa\nORDER BY consumo_total_kwh DESC",
      "user": "anonymous",
      "dateUpdated": "2026-05-03 16:13:40.401",
      "progress": 0,
      "config": {
        "editorSetting": {
          "language": "sql",
          "editOnDblClick": false,
