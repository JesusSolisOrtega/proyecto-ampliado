    {
      "title": "11. Distribucion por tramos de consumo",
      "text": "%spark.sql\nSELECT\n  CASE\n    WHEN consumo_activo_total_wh \u003d 0       THEN \u00270. Sin consumo\u0027\n    WHEN consumo_activo_total_wh \u003c 500     THEN \u00271. Bajo  (\u003c500 Wh)\u0027\n    WHEN consumo_activo_total_wh \u003c 2000    THEN \u00272. Medio (500-2000 Wh)\u0027\n    WHEN consumo_activo_total_wh \u003c 5000    THEN \u00273. Alto  (2000-5000 Wh)\u0027\n    ELSE                                        \u00274. Muy alto (\u003e5000 Wh)\u0027\n  END AS tramo,\n  COUNT(*) AS num_registros,\n  ROUND(COUNT(*) * 100.0 / SUM(COUNT(*)) OVER(), 1) AS porcentaje\nFROM consumo\nGROUP BY 1\nORDER BY 1",
      "user": "anonymous",
      "dateUpdated": "2026-05-03 16:13:40.402",
      "progress": 0,
