{
  "paragraphs": [
    {
      "title": "1. Cargar datos Parquet y crear vista SQL",
      "text": "%spark.pyspark\ndf = spark.read.parquet(\"/data/parquet_output/\")\ndf.createOrReplaceTempView(\"consumo\")\n\nprint(f\"Registros cargados: {df.count()}\")\nprint(f\"Particiones: {df.rdd.getNumPartitions()}\")\ndf.printSchema()",
      "user": "anonymous",
      "dateUpdated": "2026-05-03 16:13:40.400",
      "progress": 0,
      "config": {
        "editorSetting": {
          "language": "python",
