      "progressUpdateIntervalMs": 500,
      "jobName": "paragraph_1777824820400_2136404962",
      "id": "paragraph_02",
      "dateCreated": "2026-05-03 16:13:40.400",
      "status": "READY"
    },
    {
      "title": "3. Registros y consumo medio por año y mes",
      "text": "%spark.sql\nSELECT anyo,\n       mes,\n       COUNT(*)                                        AS num_contadores,\n       ROUND(AVG(consumo_activo_total_wh), 2)          AS consumo_activo_medio_wh,\n       ROUND(SUM(consumo_activo_total_wh) / 1000, 2)   AS consumo_activo_total_kwh\nFROM consumo\nGROUP BY anyo, mes\nORDER BY anyo, mes",
      "user": "anonymous",
      "dateUpdated": "2026-05-03 16:13:40.401",
      "progress": 0,
      "config": {
        "editorSetting": {
          "language": "sql",
          "editOnDblClick": false,
          "completionKey": "TAB",
          "completionSupport": true
        },
        "colWidth": 12.0,
        "editorMode": "ace/mode/sql",
