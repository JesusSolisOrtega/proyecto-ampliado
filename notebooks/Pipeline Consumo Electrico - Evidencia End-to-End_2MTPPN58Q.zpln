    },
    {
      "title": "5. Top 10 provincias por consumo total",
      "text": "%spark.sql\nSELECT provincia,\n       COUNT(*)                                        AS num_registros,\n       ROUND(SUM(consumo_activo_total_wh) / 1000, 2)   AS consumo_total_kwh,\n       ROUND(AVG(consumo_activo_total_wh), 2)          AS consumo_medio_wh\nFROM consumo\nGROUP BY provincia\nORDER BY consumo_total_kwh DESC\nLIMIT 10",
      "user": "anonymous",
      "dateUpdated": "2026-05-03 16:13:40.401",
      "progress": 0,
      "config": {
        "editorSetting": {
          "language": "sql",
