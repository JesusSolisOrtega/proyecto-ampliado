      "status": "READY"
    },
    {
      "title": "9. Deteccion de contadores inactivos",
      "text": "%spark.sql\nSELECT cups, tarifa, provincia, municipio,\n       COUNT(*) AS registros_sin_consumo\nFROM consumo\nWHERE consumo_activo_total_wh = 0\nGROUP BY cups, tarifa, provincia, municipio\nORDER BY registros_sin_consumo DESC\nLIMIT 10",
      "user": "anonymous",
      "dateUpdated": "2026-05-03 16:13:40.402",
      "progress": 0,
      "config": {
        "editorSetting": {
          "language": "sql",
